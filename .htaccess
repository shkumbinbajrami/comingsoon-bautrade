RewriteEngine On
RewriteBase /bautrade-coming/

# Keep direct file and directory access working (css, js, images)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Default landing
RewriteRule ^$ index.html [L]

# Clean language URLs
RewriteRule ^de/?$ de.html [L]
RewriteRule ^en/?$ en.html [L]
RewriteRule ^fr/?$ fr.html [L]
RewriteRule ^it/?$ it.html [L]
